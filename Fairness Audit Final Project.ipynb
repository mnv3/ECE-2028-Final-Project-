   ],
   "source": [
    "adult_test_pred = adult_test.copy(deepcopy=True) #convert to AIF360's data format \n",
    "adult_test_pred.labels = y_pred.reshape(-1, 1)\n",
    "#adult_test = features + true labels (the ground truth)\n",
    "#adult_test_pred = same features + model's predictions\n",
    "\n",
    "privileged = [{'sex': 1}] #define male as the privileged sex, which AIF360 requires  \n",
    "unprivileged = [{'sex': 0}] #define female as the unprivileged sex \n",
    "\n",
    "cm = ClassificationMetric(\n",
    "    adult_test, adult_test_pred,\n",
    "    unprivileged_groups=unprivileged,\n",
    "    privileged_groups=privileged,\n",
    ") #AIF360 ClassificationMetric contains the truth, model predictions, group definitions, and can compute the metrics \n",
    "\n",
    "print(f\"Disparate impact (P(Y=1|unpriv) / P(Y=1|priv)):  {cm.disparate_impact():.3f}\") #How often does the model predict 'high earner' for women, relative to men?\n",
    "#1.0 = the model says yes equally often to both groups (perfect parity)\n",
    "#0.5 = the model says yes to women only half as often as to men\n",
    "#The four-fifths rule (0.8 to 1.25) is a U.S. legal standard: the EEOC uses it to flag potentially discriminatory hiring practices. If this metric falls below 0.8, the model is in territory that would raise regulatory red flags in employment contexts.\n",
    "\n",
    "print(f\"  (1.0 = parity; 0.8-1.25 = standard 4/5 rule range)\")\n",
    "print()\n",
    "print(f\"Statistical parity difference (unpriv - priv):    {cm.statistical_parity_difference():.3f}\") #same as disparate impact but mathematically simpler\n",
    "#0.0 = parity\n",
    "#Negative = unprivileged group gets fewer positive predictions (the typical bias direction)\n",
    "\n",
    "#print(\"\\nAmong people who actually earn >$50K, does the model identify women as accurately as men?\")\n",
    "print(f\"\\nEqual opportunity difference (TPR_unpriv - TPR_priv): {cm.equal_opportunity_difference():.3f}\\n\") \n",
    "#0.0 = the model is equally good at finding qualified people in both groups\n",
    "#Negative = the model misses qualified women more often than qualified men\n",
    "\n",
    "print(f\"Average odds difference (avg of TPR + FPR diffs): {cm.average_odds_difference():.3f}\\n\")\n",
    "#The average of two gaps:\n",
    "#The TPR gap (from above )\n",
    "#The FPR gap (do unqualified women get falsely flagged at the same rate as unqualified men?)\n",
    "\n",
    "print(f\"Theil index (individual fairness, lower=fairer):  {cm.theil_index():.3f}\")\n",
    "#individual fairness metric that captures how unequally the model's predictions are distributed across all individuals, not just the protected groups.\n",
    "#0.0 = perfectly equal treatment across individuals\n",
    "#Higher = more unequal"
   ]
