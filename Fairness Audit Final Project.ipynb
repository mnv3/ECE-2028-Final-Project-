   "source": [
    "# Threshold optimizer — separate decision threshold per group, optimized for demographic parity\n",
    "to = ThresholdOptimizer( #change threshold (of yes/no classification) for each group (e.g. lower cutoff for women so they will be chosen more)\n",
    "    estimator=clf,\n",
    "    constraints='demographic_parity',\n",
    "    prefit=True,\n",
    "    predict_method='predict_proba',\n",
    ")\n",
    "to.fit(X_train_scaled, y_train, sensitive_features=sens_train) #learn thresholds of each group \n",
    "y_pred_to = to.predict(X_test_scaled, sensitive_features=sens_test) #make predictions with the new thresholds \n",
    "\n",
    "adult_test_pred_to = adult_test.copy(deepcopy=True)\n",
    "adult_test_pred_to.labels = y_pred_to.reshape(-1, 1)\n",
    "cm_to = ClassificationMetric(\n",
    "    adult_test, adult_test_pred_to,\n",
    "    unprivileged_groups=unprivileged, privileged_groups=privileged, #measure and calculate metrics again\n",
    ")\n",
    "\n",
    "print(\"After Threshold Optimization:\")\n",
    "print(f\"  Accuracy:                       {accuracy_score(y_test, y_pred_to):.3f}\")\n",
    "print(f\"  Disparate impact:               {cm_to.disparate_impact():.3f}\") #female positive prediction rate / Male positive prediction rate\n",
    "print(f\"  Statistical parity difference:  {cm_to.statistical_parity_difference():.3f}\")\n",
    "print(f\"  Equal opportunity difference:   {cm_to.equal_opportunity_difference():.3f}\")"
   ]
