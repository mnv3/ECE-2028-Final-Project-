    "RW = Reweighing(unprivileged_groups=unprivileged, privileged_groups=privileged) #apply Reweighing to the training data\n",
    "adult_train_rw = RW.fit_transform(adult_train) #compute new weights \n",
    "\n",
    "#change how much each training example counts during training. \n",
    "#Examples from underrepresented (female) class get weighted more heavily, so the model pays more attention to them and learns to be fairer\n",
    "\n",
    "clf_rw = LogisticRegression(max_iter=1000, random_state=42) #retrain new logistic model with new weights \n",
    "clf_rw.fit(\n",
    "    scaler.transform(adult_train_rw.features),\n",
    "    adult_train_rw.labels.ravel(),\n",
    "    sample_weight=adult_train_rw.instance_weights,\n",
    ")\n",
    "y_pred_rw = clf_rw.predict(X_test_scaled) #make predictions on the same test set as before  \n",
    "\n",
    "# Wrap and measure\n",
    "adult_test_pred_rw = adult_test.copy(deepcopy=True)\n",
    "adult_test_pred_rw.labels = y_pred_rw.reshape(-1, 1)\n",
    "cm_rw = ClassificationMetric(\n",
    "    adult_test, adult_test_pred_rw,\n",
    "    unprivileged_groups=unprivileged, privileged_groups=privileged, #measure fairness and other ClassificationMetrics\n",
    ")\n",
    "\n",
    "print(\"After Reweighing:\")\n",
    "print(f\"  Accuracy:                       {accuracy_score(y_test, y_pred_rw):.3f}\")\n",
    "print(f\"  Disparate impact:               {cm_rw.disparate_impact():.3f}\")\n",
    "print(f\"  Statistical parity difference:  {cm_rw.statistical_parity_difference():.3f}\")\n",
    "print(f\"  Equal opportunity difference:   {cm_rw.equal_opportunity_difference():.3f}\")"
