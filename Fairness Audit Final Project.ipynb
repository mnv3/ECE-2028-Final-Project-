   "source": [
    "def recommend_audit_model(stakes, visibility, regulation, conflict, community_input):\n",
    "    for name, val in [('stakes', stakes), ('visibility', visibility),\n",
    "                      ('regulation', regulation), ('conflict', conflict),\n",
    "                      ('community_input', community_input)]:\n",
    "        if not (0 <= val <= 3):\n",
    "            raise ValueError(f\"{name} must be between 0 and 3, got {val}\")\n",
    "\n",
    "    total = stakes + visibility + regulation + conflict + community_input\n",
    "    max_score = 15\n",
    "\n",
    "    print(f\"Score breakdown:\")\n",
    "    print(f\"  Stakes:                       {stakes}/3\")\n",
    "    print(f\"  Public visibility:            {visibility}/3\")\n",
    "    print(f\"  Regulatory pressure:          {regulation}/3\")\n",
    "    print(f\"  Internal conflict-of-interest: {conflict}/3\")\n",
    "    print(f\"  Community input availability: {community_input}/3\")\n",
    "    print(f\"  TOTAL:                        {total}/{max_score}\")\n",
    "    print()\n",
    "\n",
    "    if total <= 5:\n",
    "        rec = \"INTERNAL-ONLY AUDIT\"\n",
    "        rationale = (\n",
    "            \"The system appears to be low-stakes with limited public exposure and weak conflict-of-interest concerns. An internal audit by the \"\n",
    "            \"development team or compliance group is probably enough. Document the methodology so it can be revisited if the deployment \"\n",
    "            \"context changes.\"\n",
    "        )\n",
    "    elif total <= 10:\n",
    "        rec = \"HYBRID AUDIT (Internal measurement + External validation)\"\n",
    "        rationale = (\n",
    "            \"The system has moderate stakes or visibility, or some conflict-of-interest concerns. Internal teams should perform the \"\n",
    "            \"initial measurement and mitigation, but an external, unbiased reviewer should validate the methodology, reproduce key metrics, and sign \"\n",
    "            \"off on the final report. If the community input is low, prioritize engaging affected groups before deployment.\"\n",
    "        )\n",
    "    else:\n",
    "        rec = \"FULL EXTERNAL AUDIT WITH MANDATORY COMMUNITY ENGAGEMENT\"\n",
    "        rationale = (\n",
    "            \"The system is high-stakes, publicly visible, and operates in a context where conflicts of interest and regulatory exposure are significant. An external independent audit is required, and affected communities should be formally engaged in defining what constitutes acceptable disparity.\" \n",
    "            \"Internal audits alone cannot produce a trustworthy result.\"\n",
    "        )\n",
    "\n",
    "    print(f\"RECOMMENDATION: {rec}\")\n",
    "    print()\n",
    "    print(rationale)\n",
    "    return rec, total\n",
    "\n",
    "\n",
    "#example: run the assessment for the UCI Adult classifier as if it were being deployed for real-world income screening (e.g. loan approvals).\n",
    "print(\"=\" * 70)\n",
    "print(\"ASSESSMENT: UCI Adult classifier deployed for real-world income screening\")\n",
    "print(\"=\" * 70)\n",
    "print()\n",
    "recommend_audit_model(\n",
    "    stakes=3,            # high, because it affects access to credit and approval for loans, etc.\n",
    "    visibility=2,        # mmoderate, because it affects many individuals, but might not be on the news \n",
    "    regulation=3,        # high, it is regulated by ECOA, fair lending practices, four-fifths rule\n",
    "    conflict=2,          # moderate, because developers have shipping incentives\n",
    "    community_input=1,   # low, people do not really have a say in what is defined as acceptable when it comes to loan approvals and commercial interests\n",
    ")\n"
   ]
